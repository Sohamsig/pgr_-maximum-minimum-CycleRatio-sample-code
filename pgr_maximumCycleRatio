#include <iostream>
#include <vector>
#include <boost/graph/adjacency_list.hpp>
#include <boost/graph/howard_cycle_ratio.hpp>

using namespace boost;

int main() {

    typedef adjacency_list<
        vecS, vecS, directedS,
        no_property,
        property<edge_weight_t, double>
    > Graph;

    Graph g(4);

    auto w = get(edge_weight, g);

    add_edge(0,1,3.0,g);
    add_edge(1,2,2.0,g);
    add_edge(2,3,4.0,g);
    add_edge(3,1,1.0,g);

    auto vim = get(vertex_index, g);

    std::vector<graph_traits<Graph>::edge_descriptor> cycle;

    double ratio = maximum_cycle_ratio(
        g,
        vim,
        w,
        w,
        &cycle
    );

    std::cout << "Maximum Cycle Ratio: " << ratio << std::endl;

    return 0;
}
